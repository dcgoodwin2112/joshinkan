---
import SumiLayout from '~/layouts/SumiLayout.astro';
import Schedule from '~/components/sumi/Schedule.astro';
import Map from '~/components/Map.astro';
import { CONTACT, LINKS, DUES } from '~/data/site';
---

<SumiLayout
  title="Visit: Joshinkan Dojo"
  description="Class schedule, dues, location, and contact information for Joshinkan Dojo in Cary, NC."
>
  <div class="page-head">
    <h1>Visit the dojo</h1>
    <span class="page-kanji">稽古</span>
  </div>

  <section>
    <p class="section-eyebrow">Schedule</p>
    <h2 class="section-title">Class times.</h2>
    <Schedule />
    <p style="margin-top: 36px; font-style: italic; color: var(--ink-muted); font-family: var(--serif-d); font-size: 20px;">
      Should you have any questions, or you are interested in joining the dojo, please stop by anytime during regularly scheduled classes. Visitors are always welcome to observe.
    </p>
  </section>

  <section>
    <p class="section-eyebrow">Membership</p>
    <h2 class="section-title">How to begin.</h2>
    <div class="info-grid">
      <div class="info-block">
        <h3>If you are new to Aikido</h3>
        <p>Join for one month and attend as many classes as you can. You will be paired with an instructor who will work with you on basic movements and how to safely train. If after the introductory month you wish to continue, we set up your membership.</p>
      </div>
      <div class="info-block">
        <h3>If you have trained before</h3>
        <p>Please meet with Sensei Whatley about membership. If you are visiting the area and currently train at a dojo, you are most welcome to come visit us and train.</p>
      </div>
    </div>
    <div class="info-grid" style="margin-top: 48px;">
      <div class="info-block">
        <h3>Monthly dues</h3>
        <p class="big">${DUES.monthly}</p>
        <p>Per month. No contracts.</p>
      </div>
      <div class="info-block">
        <h3>What to wear</h3>
        <p>For your first visits, loose comfortable clothing is fine. A traditional <em>dogi</em> can be acquired once you decide to continue.</p>
      </div>
    </div>
  </section>

  <section>
    <p class="section-eyebrow">Location</p>
    <h2 class="section-title">{CONTACT.address.street}, {CONTACT.address.cityStateZip.split(',')[0]}.</h2>
    <p class="prose">The dojo is located inside Master Chang's Taekwondo, off High House Road in Cary. Parking is available on site.</p>
    <div class="map-block"><Map /></div>
  </section>

  <section>
    <p class="section-eyebrow">Contact</p>
    <h2 class="section-title">Get in touch.</h2>
    <dl class="contact-list">
      <div>
        <dt>address</dt>
        <dd>
          {CONTACT.address.street}<br />
          {CONTACT.address.cityStateZip}<br />
          <span style="color: var(--ink-muted); font-size: 16px;">({CONTACT.address.note.toLowerCase()})</span>
        </dd>
      </div>
      <div>
        <dt>phone</dt>
        <dd><a href={`tel:${CONTACT.phoneTel}`}>{CONTACT.phone}</a></dd>
      </div>
      <div>
        <dt>email</dt>
        <dd><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></dd>
      </div>
      <div>
        <dt>also at</dt>
        <dd><a href={LINKS.facebook} target="_blank" rel="noopener">Facebook</a></dd>
      </div>
    </dl>
  </section>
</SumiLayout>
