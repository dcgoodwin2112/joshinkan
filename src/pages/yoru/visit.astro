---
import YoruLayout from '~/layouts/YoruLayout.astro';
import Schedule from '~/components/yoru/Schedule.astro';
import Map from '~/components/Map.astro';
import { CONTACT, LINKS, DUES } from '~/data/site';
---

<YoruLayout
  title="Visit: Joshinkan Dojo"
  description="Class schedule, dues, location, and contact information for Joshinkan Dojo in Cary, NC."
>
  <div class="page-head">
    <div class="meta-row"><span>Page 03 of 03</span><span class="amber">Visit</span><span>Schedule, dues, location, contact</span></div>
    <h1>Plan your <em>visit</em>.</h1>
    <p class="subtitle">Everything you need to come for a class or start your introductory month.</p>
  </div>

  <section>
    <div class="sec-header"><span class="sec-code">0.1 / Schedule</span><h2 class="section-title">Class <em>times</em>.</h2></div>
    <Schedule />
    <p style="margin-top: 40px; font-family: var(--serif); font-style: italic; color: var(--cream-soft); font-size: 20px;">Stop by anytime during regularly scheduled classes. Visitors are always welcome to observe.</p>
  </section>

  <section>
    <div class="sec-header"><span class="sec-code">0.2 / Membership</span><h2 class="section-title">How to <em>begin</em>.</h2></div>
    <div class="two-col">
      <div class="col"><h3>New to Aikido</h3><p class="prose">Join for one month and attend as many classes as you can. You will be paired with an instructor who will work with you on basic movements and how to safely train. After the introductory month, if you wish to continue, we set up your membership.</p></div>
      <div class="col"><h3>Trained before</h3><p class="prose">Please meet with Sensei Whatley about membership. If you are visiting the area and currently train at a dojo, you are most welcome to come visit us and train.</p></div>
    </div>
    <div class="info-grid">
      <div class="info-card"><span class="num">i.</span><h3>Monthly dues</h3><p class="big">${DUES.monthly}</p><p>Per month. No contracts.</p></div>
      <div class="info-card"><span class="num">ii.</span><h3>Intro period</h3><p class="big">{DUES.introMonths} month</p><p>Attend as many classes as you can.</p></div>
      <div class="info-card"><span class="num">iii.</span><h3>What to wear</h3><p style="font-family: var(--serif); font-size: 28px; color: var(--cream); margin: 12px 0 8px; font-style: italic; font-weight: 300;">Loose clothing.</p><p>A traditional <em>dogi</em> can be acquired once you decide to continue.</p></div>
    </div>
  </section>

  <section>
    <div class="sec-header"><span class="sec-code">0.3 / Location</span><h2 class="section-title">944 High House <em>Rd</em>.</h2></div>
    <p class="prose">The dojo is located inside <strong>Master Chang's Taekwondo</strong>, just off High House Road in Cary. Parking is available on site. Five minutes from downtown Cary, twenty from downtown Raleigh.</p>
    <div class="map-block"><Map /></div>
  </section>

  <section>
    <div class="sec-header"><span class="sec-code">0.4 / Contact</span><h2 class="section-title">Get in <em>touch</em>.</h2></div>
    <div class="contact-list">
      <div class="item"><div class="label">Address</div><div class="value">{CONTACT.address.street}<br />{CONTACT.address.cityStateZip}</div><div class="note">{CONTACT.address.note}</div></div>
      <div class="item"><div class="label">Phone</div><div class="value"><a href={`tel:${CONTACT.phoneTel}`}>{CONTACT.phone}</a></div></div>
      <div class="item"><div class="label">Email</div><div class="value"><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></div></div>
      <div class="item"><div class="label">Social</div><div class="value"><a href={LINKS.facebook} target="_blank" rel="noopener">Facebook</a></div></div>
    </div>
  </section>
</YoruLayout>
