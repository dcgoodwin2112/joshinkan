---
// Tri-state theme toggle: auto -> light -> dark -> auto.
// Reads/writes localStorage.theme; updates <html data-theme> and data-theme-mode.
// The blocking init script in Layout.astro sets the initial state before paint.
---

<button
  type="button"
  class="theme-toggle"
  aria-label="Theme"
  data-theme-toggle
>
  <svg class="ti ti-auto" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="9"></circle>
    <path d="M12 3a9 9 0 0 0 0 18z" fill="currentColor"></path>
  </svg>
  <svg class="ti ti-light" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="M4.93 4.93l1.41 1.41"></path>
    <path d="M17.66 17.66l1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="M4.93 19.07l1.41-1.41"></path>
    <path d="M17.66 6.34l1.41-1.41"></path>
  </svg>
  <svg class="ti ti-dark" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    const btn = document.querySelector('[data-theme-toggle]');
    if (!btn) return;
    const root = document.documentElement;
    const order = ['auto', 'light', 'dark'];
    const labels = { auto: 'Theme: auto (system)', light: 'Theme: light', dark: 'Theme: dark' };

    function effective(mode) {
      return mode === 'dark' || (mode === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)
        ? 'dark'
        : 'light';
    }

    function apply(mode) {
      root.dataset.themeMode = mode;
      root.dataset.theme = effective(mode);
      btn.setAttribute('aria-label', labels[mode]);
      btn.setAttribute('title', labels[mode]);
    }

    // Sync from whatever the inline init script in <head> set (or default).
    apply(root.dataset.themeMode || 'auto');

    btn.addEventListener('click', function () {
      const current = root.dataset.themeMode || 'auto';
      const next = order[(order.indexOf(current) + 1) % order.length];
      try { localStorage.setItem('theme', next); } catch (e) {}
      apply(next);
    });

    // Re-evaluate when the OS preference changes, but only while in auto mode.
    const mq = window.matchMedia('(prefers-color-scheme: dark)');
    const onChange = function () {
      if (root.dataset.themeMode === 'auto') apply('auto');
    };
    if (mq.addEventListener) mq.addEventListener('change', onChange);
    else if (mq.addListener) mq.addListener(onChange);
  })();
</script>

<style>
  .theme-toggle {
    background: none;
    border: 0;
    padding: 6px;
    cursor: pointer;
    color: var(--char-soft);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
    border-radius: 4px;
  }
  .theme-toggle:hover {
    color: var(--clay);
  }
  .theme-toggle:focus-visible {
    outline: 2px solid var(--clay);
    outline-offset: 2px;
  }
  .theme-toggle .ti { display: none; }
  :root[data-theme-mode='auto'] .theme-toggle .ti-auto { display: inline-block; }
  :root[data-theme-mode='light'] .theme-toggle .ti-light { display: inline-block; }
  :root[data-theme-mode='dark'] .theme-toggle .ti-dark { display: inline-block; }

  /* Match the hamburger button's hit area on mobile so the two focus rings
     are the same size when tabbed. Icon stays 18×18, centered by inline-flex. */
  @media (max-width: 700px) {
    .theme-toggle { width: 40px; height: 40px; padding: 0; }
  }
</style>
