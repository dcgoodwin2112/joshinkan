---
import { SITE, CONTACT, LINKS, NAV } from '~/data/site';
const variant = 'kaze';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div>
    <div class="brand-footer">{SITE.brand}</div>
    <p>The Center for Aikido Study is a 501(c) nonprofit. All instructors volunteer their time, and all dues maintain the dojo.</p>
  </div>
  <div>
    <h4>Visit</h4>
    <ul>
      <li>{CONTACT.address.street}</li>
      <li>{CONTACT.address.cityStateZip}</li>
      <li>{CONTACT.phone}</li>
    </ul>
  </div>
  <div>
    <h4>Site</h4>
    <ul>
      {NAV.map(({ label, href }) => (
        <li><a href={href === '/' ? `/${variant}` : `/${variant}${href}`}>{label}</a></li>
      ))}
    </ul>
  </div>
  <div>
    <h4>Elsewhere</h4>
    <ul>
      <li><a href={LINKS.aaa} target="_blank" rel="noopener">AAA</a></li>
      <li><a href={LINKS.facebook} target="_blank" rel="noopener">Facebook</a></li>
      <li><a href={LINKS.triangle} target="_blank" rel="noopener">Triangle Aikido</a></li>
    </ul>
  </div>
  <div class="copyright">
    <span>© {year} Center for Aikido Study, Joshinkan Dojo</span>
    <span>Cary, North Carolina</span>
  </div>
</footer>
