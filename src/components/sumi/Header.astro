---
import { SITE, NAV } from '~/data/site';

const variant = 'sumi';
const currentPath = Astro.url.pathname.replace(/\/$/, '') || `/${variant}`;
---

<header class="site-header">
  <div class="brand">
    <span class="brand-mark"><a href={`/${variant}`}>{SITE.brand}</a></span>
    <span class="brand-kanji">{SITE.kanji}</span>
  </div>
  <nav class="site-nav" aria-label="Primary">
    {NAV.map(({ label, href }) => {
      const targetHref = href === '/' ? `/${variant}` : `/${variant}${href}`;
      const isCurrent = href === '/'
        ? currentPath === `/${variant}`
        : currentPath === `/${variant}${href}` || currentPath.startsWith(`/${variant}${href}/`);
      return (
        <a href={targetHref} class:list={[{ 'is-current': isCurrent }]}>{label}</a>
      );
    })}
  </nav>
</header>
