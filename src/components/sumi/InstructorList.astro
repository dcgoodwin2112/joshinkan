---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

const all = await getCollection('instructors');
const instructors = all.sort((a, b) => a.data.order - b.data.order);
---

<div class="instructors">
  {await Promise.all(instructors.map(async (entry) => {
    const { Content } = await render(entry);
    return (
      <article class="instructor">
        <div class="instructor-portrait">
          {entry.data.photo
            ? <Image src={entry.data.photo} alt={entry.data.name} loading="lazy" widths={[200, 400]} sizes="(min-width: 768px) 200px, 50vw" />
            : 'Portrait'}
        </div>
        <div>
          <h3>{entry.data.name}</h3>
          <p class="rank">{entry.data.rank}, {entry.data.rankNote}</p>
          <div class="prose">
            <Content />
          </div>
        </div>
      </article>
    );
  }))}
</div>
